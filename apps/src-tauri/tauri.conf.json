{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "vite build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  },
  "productName": "Leaflet",
  "version": "0.1.0",
  "identifier": "com.leaflet.app",
  "plugins": {},
  "app": {
    "windows": [
      {
        "title": "Leaflet",
        "width": 1600,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPDATA/leaflet/**",
          "$APPDATA/leaflet/covers/**",
          "$APPDATA/leaflet/books/**"
        ]
      },
      "capabilities": [
        "default"
      ]
    }
  }
}
